let activeLessonIdx = 0;
let activeCourse = null;

function openCourse(course) {
  if (!course || !course.modules_list) {
    if (course && course.status === 'completed') {
      alert(`🎓 Certificate for "${course.title}" — downloading PDF...`);
    }
    return;
  }
  activeCourse = course;

  // find active lesson
  let idx = 0;
  let flatLessons = [];
  course.modules_list.forEach(mod => {
    mod.lessons.forEach(l => {
      flatLessons.push({ ...l, modTitle: mod.title });
    });
  });
  activeLessonIdx = flatLessons.findIndex(l => l.active);
  if (activeLessonIdx < 0) activeLessonIdx = flatLessons.filter(l => l.done).length;

  document.getElementById('modal-course-title').textContent = course.title;
  document.getElementById('modal-prog-label').textContent = course.progress + '%';
  document.getElementById('modal-mini-fill').style.width = course.progress + '%';

  renderLessonSidebar(course, activeLessonIdx);
  renderLessonContent(course, activeLessonIdx);
  document.getElementById('lessonModal').classList.add('open');
}

function renderLessonSidebar(course, activeIdx) {
  const sb = document.getElementById('lessonSidebar');
  sb.innerHTML = `
    <div class="ls-header">
      <div class="ls-course-title">${course.title}</div>
      <div class="ls-stats">
        <span>📋 ${course.modules} modules</span>
        <span>⏱ ${course.hours}h total</span>
      </div>
    </div>
  `;

  let flatIdx = 0;
  course.modules_list.forEach(mod => {
    const grp = document.createElement('div');
    grp.className = 'module-group';
    grp.innerHTML = `<div class="module-title">${mod.title}</div>`;

    mod.lessons.forEach(l => {
      const currIdx = flatIdx;
      const isDone = l.done;
      const isActive = currIdx === activeIdx;
      const li = document.createElement('div');
      li.className = 'lesson-item' + (isActive ? ' active' : '') + (isDone ? ' done' : '');
      li.innerHTML = `
        <div class="li-status ${isDone ? 'done' : isActive ? 'active' : 'locked'}">
          ${isDone ? '✓' : isActive ? '▶' : '○'}
        </div>
        <div class="li-name">${l.name}</div>
        <div class="li-dur">${l.dur}</div>
      `;
      li.onclick = () => {
        activeLessonIdx = currIdx;
        renderLessonSidebar(course, currIdx);
        renderLessonContent(course, currIdx);
      };
      grp.appendChild(li);
      flatIdx++;
    });
    sb.appendChild(grp);
  });
}

