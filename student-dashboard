function fmtTime(h, m) {
  const period = h < 12 || h === 24 ? 'AM' : 'PM';
  let displayH = h % 24;
  if (displayH === 0) displayH = 12;
  else if (displayH > 12) displayH -= 12;
  return displayH + (m ? ':' + String(m).padStart(2,'0') : '') + ' ' + period;
}

function convertPHTtoTZ(dayName, startH, startM, endH, endM, targetTZ) {
  // PHT = UTC+8. Build a reference date using a known day mapping.
  const dayMap = { Sunday:0, Monday:1, Tuesday:2, Wednesday:3, Thursday:4, Friday:5, Saturday:6 };
  const dayIdx = dayMap[dayName];
  // Use 2025-01-05 as a Sunday anchor (Jan 5 2025 = Sunday)
  const baseDate = new Date(2025, 0, 5 + dayIdx); // local date object for day calculation

  // Create UTC times: PHT = UTC+8, so UTC = PHT - 8
  const startUTCH = startH - 8;
  const endUTCH   = endH   - 8;

  // Build Date objects at exact UTC moments
  const startUTC = new Date(Date.UTC(2025, 0, 5 + dayIdx, startUTCH, startM, 0));
  const endUTC   = new Date(Date.UTC(2025, 0, 5 + dayIdx, endUTCH,   endM,   0));

  const dayNames = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];

  // Format in target timezone
  const opts = { timeZone: targetTZ, weekday:'long', hour:'numeric', minute:'2-digit', hour12: true };
  const startLocal = new Intl.DateTimeFormat('en-US', opts).format(startUTC);
  const endLocal   = new Intl.DateTimeFormat('en-US', { timeZone: targetTZ, hour:'numeric', minute:'2-digit', hour12: true }).format(endUTC);

  // Get local day name
  const localDayFmt = new Intl.DateTimeFormat('en-US', { timeZone: targetTZ, weekday:'long' });
  const localDay = localDayFmt.format(startUTC);

  // Get TZ abbreviation
  try {
    const tzAbbrStr = new Intl.DateTimeFormat('en-US', { timeZone: targetTZ, timeZoneName: 'short' }).format(startUTC);
    const tzAbbr = tzAbbrStr.split(',').pop().trim().split(' ').pop();
    return { localDay, startStr: startLocal.split(',').pop().trim(), endStr: endLocal, tzAbbr };
  } catch(e) {
    return { localDay, startStr: startLocal, endStr: endLocal, tzAbbr: '' };
  }
}

function updateSchedTimes() {
  const data = currentSchedData;
  if (!data) return;
  const tz = document.getElementById('tzSelect').value;
  const isPHT = tz === 'Asia/Manila';

  const container = document.getElementById('schedDays');
  container.innerHTML = '';

  data.sessions.forEach((s, i) => {
    const row = document.createElement('div');
    row.className = 'sched-day-row';

    const phStart = fmtTime(s.startH, s.startM);
    const phEnd   = fmtTime(s.endH,   s.endM);

    let localHTML = '';
    if (!isPHT) {
      try {
        const conv = convertPHTtoTZ(s.day, s.startH, s.startM, s.endH, s.endM, tz);
        localHTML = `
          <div class="sched-time-local">
            <div>${conv.startStr} – ${conv.endStr}</div>
            <div class="local-tz-label">${conv.localDay} · ${conv.tzAbbr}</div>
          </div>
        `;
      } catch(e) { localHTML = ''; }
    }

    row.innerHTML = `
      <div class="sched-day-left">
        <div class="day-dot" style="background:${data.accentColor};box-shadow:0 0 6px ${data.accentColor}66;"></div>
        <div class="day-name">${s.day}</div>
        <div class="sched-time-ph">${phStart} – ${phEnd} PHT</div>
      </div>
      ${localHTML}
    `;
    container.appendChild(row);
  });
}

