<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Learning — Nex Genix Business School</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Exo+2:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #070c14;
    --bg-card: #0c1520;
    --bg-card2: #101d2b;
    --bg-nav: #080e18;
    --cyan: #00d4ff;
    --cyan-dim: rgba(0,212,255,0.12);
    --gold: #f0a500;
    --gold-dim: rgba(240,165,0,0.12);
    --green: #00e676;
    --green-dim: rgba(0,230,118,0.12);
    --orange: #ff6d00;
    --red: #ff3d57;
    --purple: #b388ff;
    --purple-dim: rgba(179,136,255,0.12);
    --text: #ddeeff;
    --text-2: #6a90aa;
    --text-3: #2d4a60;
    --border: rgba(0,212,255,0.1);
    --border-2: rgba(0,212,255,0.25);
    --r: 12px;
    --r-sm: 8px;
  }

  *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

  body {
    font-family: 'Exo 2', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* dot grid */
  body::before {
    content: '';
    position: fixed; inset: 0;
    background-image: radial-gradient(circle, rgba(0,212,255,0.06) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none; z-index: 0;
  }

  /* ambient glow */
  body::after {
    content: '';
    position: fixed;
    top: -200px; left: 50%; transform: translateX(-50%);
    width: 800px; height: 400px;
    background: radial-gradient(ellipse, rgba(0,212,255,0.04) 0%, transparent 70%);
    pointer-events: none; z-index: 0;
  }

  /* ── NAV ── */
  nav {
    position: sticky; top: 0; z-index: 100;
    background: rgba(8,14,24,0.96);
    backdrop-filter: blur(24px);
    border-bottom: 1px solid var(--border);
    height: 58px;
    display: flex; align-items: center;
    padding: 0 28px;
    justify-content: space-between;
  }

  .brand {
    display: flex; align-items: center; gap: 10px;
  }

  .brand-logo {
    width: 30px; height: 30px;
    background: linear-gradient(135deg,#f03,#f80,#fd0,#0d4,#09f,#84f);
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Orbitron',monospace; font-size: 12px; font-weight: 900; color: #fff;
  }

  .brand-name {
    font-family: 'Orbitron', monospace;
    font-size: 10px; font-weight: 600;
    letter-spacing: 3px; color: var(--text);
    text-transform: uppercase;
  }

  .nav-center {
    display: flex; gap: 2px;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border);
    border-radius: var(--r-sm);
    padding: 3px;
  }

  .nav-tab {
    padding: 5px 16px;
    border-radius: 6px;
    font-size: 12px; font-weight: 600;
    cursor: pointer; border: none; background: transparent;
    color: var(--text-2);
    font-family: 'Exo 2', sans-serif;
    transition: all 0.2s;
    display: flex; align-items: center; gap: 5px;
  }

  .nav-tab:hover { color: var(--text); }
  .nav-tab.active { background: var(--cyan); color: #000; font-weight: 700; }

  .nav-right {
    display: flex; align-items: center; gap: 10px;
  }

  .avatar {
    width: 32px; height: 32px; border-radius: 50%;
    background: linear-gradient(135deg, var(--cyan), var(--purple));
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 13px; color: #000; cursor: pointer;
    border: 2px solid rgba(0,212,255,0.3);
  }

  .notif-btn {
    width: 32px; height: 32px; border-radius: var(--r-sm);
    background: var(--bg-card); border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; font-size: 14px; position: relative;
    transition: border-color 0.2s;
  }
  .notif-btn:hover { border-color: var(--cyan); }

  .notif-dot {
    position: absolute; top: 5px; right: 5px;
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--red); border: 1px solid var(--bg-card);
  }

  .btn-sm {
    padding: 6px 14px; border-radius: 6px;
    font-family: 'Exo 2', sans-serif; font-size: 11px; font-weight: 700;
    cursor: pointer; border: none;
    display: flex; align-items: center; gap: 5px;
    transition: all 0.2s; text-transform: uppercase; letter-spacing: 0.5px;
  }

  .btn-catalog { background: transparent; border: 1px solid var(--border); color: var(--text-2); }
  .btn-catalog:hover { border-color: var(--cyan); color: var(--cyan); }
  .btn-logout { background: rgba(255,61,87,0.15); border: 1px solid rgba(255,61,87,0.3); color: var(--red); }
  .btn-logout:hover { background: var(--red); color: #fff; }

  /* ── LAYOUT ── */
  .layout {
    display: flex;
    min-height: calc(100vh - 58px);
    position: relative; z-index: 1;
  }

  /* ── SIDEBAR ── */
  .sidebar {
    width: 220px; flex-shrink: 0;
    background: var(--bg-nav);
    border-right: 1px solid var(--border);
    padding: 20px 12px;
    position: sticky; top: 58px;
    height: calc(100vh - 58px);
    overflow-y: auto;
    display: flex; flex-direction: column; gap: 24px;
  }

  .sidebar-group label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px; font-weight: 600; letter-spacing: 2px;
    color: var(--text-3); text-transform: uppercase;
    padding: 0 8px; display: block; margin-bottom: 6px;
  }

  .s-item {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 10px; border-radius: var(--r-sm);
    cursor: pointer; font-size: 12px; font-weight: 500;
    color: var(--text-2); border: 1px solid transparent;
    transition: all 0.2s; text-decoration: none;
  }
  .s-item:hover { color: var(--cyan); background: var(--cyan-dim); border-color: var(--border); }
  .s-item.active { color: var(--cyan); background: var(--cyan-dim); border-color: rgba(0,212,255,0.2); }
  .s-item .ico { font-size: 14px; }
  .s-item .pill {
    margin-left: auto;
    background: var(--cyan); color: #000;
    font-size: 8px; font-weight: 700; padding: 1px 5px;
    border-radius: 8px; font-family: 'JetBrains Mono', monospace;
  }
  .s-item .pill.g { background: var(--green); }
  .s-item .pill.o { background: var(--gold); }

  /* ── MAIN ── */
  .main {
    flex: 1; padding: 28px 32px;
    overflow-y: auto;
  }

  /* ── WELCOME STRIP ── */
  .welcome-strip {
    background: linear-gradient(135deg, rgba(0,212,255,0.06) 0%, rgba(179,136,255,0.04) 100%);
    border: 1px solid rgba(0,212,255,0.15);
    border-radius: var(--r);
    padding: 20px 24px;
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 24px;
    position: relative; overflow: hidden;
  }

  .welcome-strip::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, var(--cyan), var(--purple), var(--cyan));
    background-size: 200% 100%;
    animation: shimmer 3s linear infinite;
  }

  @keyframes shimmer {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }

  .welcome-text h2 {
    font-family: 'Orbitron', monospace;
    font-size: 18px; font-weight: 700; color: var(--text);
    margin-bottom: 4px;
  }

  .welcome-text p { font-size: 13px; color: var(--text-2); }
  .welcome-text p span { color: var(--cyan); font-weight: 600; }

  .welcome-xp {
    text-align: right;
  }

  .xp-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; color: var(--text-3); letter-spacing: 1px;
    text-transform: uppercase; margin-bottom: 4px;
  }

  .xp-bar-wrap {
    width: 180px; height: 6px;
    background: rgba(255,255,255,0.06);
    border-radius: 3px; overflow: hidden; margin-bottom: 4px;
  }

  .xp-bar {
    height: 100%;
    background: linear-gradient(90deg, var(--cyan), var(--purple));
    border-radius: 3px;
    width: 62%;
    animation: growBar 1.2s ease-out;
  }

  @keyframes growBar {
    from { width: 0; }
    to { width: 62%; }
  }

  .xp-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; color: var(--text-2);
  }

  /* ── QUICK STATS ── */
  .quick-stats {
    display: grid; grid-template-columns: repeat(4,1fr); gap: 12px;
    margin-bottom: 28px;
  }

  .qs-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--r);
    padding: 14px 16px;
    display: flex; align-items: center; gap: 12px;
    transition: border-color 0.2s, transform 0.2s;
    cursor: default;
  }

  .qs-card:hover { border-color: var(--border-2); transform: translateY(-1px); }

  .qs-icon {
    width: 38px; height: 38px; border-radius: var(--r-sm);
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; flex-shrink: 0;
  }

  .qs-val {
    font-family: 'Orbitron', monospace;
    font-size: 20px; font-weight: 700;
    line-height: 1;
  }

  .qs-lbl {
    font-size: 10px; color: var(--text-2);
    text-transform: uppercase; letter-spacing: 0.8px;
    margin-top: 2px;
  }

  /* ── SECTION HEADER ── */
  .sec-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 16px;
  }

  .sec-title {
    font-family: 'Orbitron', monospace;
    font-size: 13px; font-weight: 700; letter-spacing: 1px;
    display: flex; align-items: center; gap: 8px;
  }

  .sec-link {
    font-size: 11px; color: var(--cyan); cursor: pointer;
    font-family: 'JetBrains Mono', monospace;
    text-decoration: none; border-bottom: 1px solid rgba(0,212,255,0.3);
    transition: border-color 0.2s;
  }

  .sec-link:hover { border-color: var(--cyan); }

  /* ── CONTINUE LEARNING ── */
  .continue-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(300px,1fr));
    gap: 14px; margin-bottom: 32px;
  }

  .course-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--r);
    overflow: hidden;
    transition: all 0.25s;
    cursor: pointer;
    position: relative;
    animation: fadeSlideUp 0.4s ease both;
  }

  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .course-card:nth-child(1) { animation-delay: 0.05s; }
  .course-card:nth-child(2) { animation-delay: 0.1s; }
  .course-card:nth-child(3) { animation-delay: 0.15s; }
  .course-card:nth-child(4) { animation-delay: 0.2s; }
  .course-card:nth-child(5) { animation-delay: 0.25s; }

  .course-card:hover {
    border-color: var(--border-2);
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.35), 0 0 0 1px rgba(0,212,255,0.12);
  }

  .card-color-bar {
    height: 3px; width: 100%;
  }

  .card-body { padding: 14px 16px 12px; }

  .card-meta-top {
    display: flex; align-items: center; gap: 8px; margin-bottom: 8px;
  }

  .course-id-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px; color: var(--text-3);
    background: var(--bg-card2);
    border: 1px solid var(--border);
    padding: 2px 6px; border-radius: 4px;
  }

  .cat-tag {
    font-size: 9px; font-weight: 700; padding: 2px 7px;
    border-radius: 4px; text-transform: uppercase;
    font-family: 'JetBrains Mono', monospace;
  }

  .card-title {
    font-weight: 700; font-size: 14px; color: var(--gold);
    line-height: 1.35; margin-bottom: 10px;
  }

  /* progress */
  .prog-wrap {
    margin-bottom: 10px;
  }

  .prog-info {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 5px;
  }

  .prog-label {
    font-size: 10px; color: var(--text-2);
    font-family: 'JetBrains Mono', monospace;
  }

  .prog-pct {
    font-size: 11px; font-weight: 700;
    font-family: 'JetBrains Mono', monospace;
  }

  .prog-bar {
    height: 5px; background: rgba(255,255,255,0.06);
    border-radius: 3px; overflow: hidden;
  }

  .prog-fill {
    height: 100%; border-radius: 3px;
    transition: width 1s ease;
  }

  /* current lesson */
  .cur-lesson {
    background: var(--bg-card2);
    border: 1px solid var(--border);
    border-radius: var(--r-sm);
    padding: 8px 10px;
    display: flex; align-items: center; gap: 8px;
    margin-bottom: 12px;
  }

  .lesson-icon {
    width: 26px; height: 26px; border-radius: 5px;
    background: var(--cyan-dim);
    border: 1px solid rgba(0,212,255,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; flex-shrink: 0;
  }

  .lesson-info { flex: 1; min-width: 0; }

  .lesson-subtitle {
    font-size: 9px; color: var(--text-3); letter-spacing: 1px;
    text-transform: uppercase; font-family: 'JetBrains Mono', monospace;
  }

  .lesson-name {
    font-size: 11px; font-weight: 600; color: var(--text);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  .card-footer {
    padding: 10px 16px;
    border-top: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
    gap: 8px;
  }

  .card-stats {
    display: flex; gap: 10px;
  }

  .cs-item {
    font-size: 9px; color: var(--text-3);
    font-family: 'JetBrains Mono', monospace;
    display: flex; align-items: center; gap: 3px;
  }

  .btn-continue {
    padding: 7px 14px;
    border-radius: var(--r-sm);
    font-family: 'Exo 2', sans-serif;
    font-size: 11px; font-weight: 700;
    cursor: pointer; border: none;
    display: flex; align-items: center; gap: 5px;
    transition: all 0.2s;
    text-transform: uppercase; letter-spacing: 0.5px;
  }

  /* ── COMPLETED STRIP ── */
  .completed-strip {
    display: flex; gap: 12px;
    overflow-x: auto; padding-bottom: 8px;
    margin-bottom: 32px;
    scrollbar-width: none;
  }

  .completed-strip::-webkit-scrollbar { display: none; }

  .cert-card {
    background: var(--bg-card);
    border: 1px solid rgba(240,165,0,0.2);
    border-radius: var(--r);
    padding: 16px;
    min-width: 220px;
    flex-shrink: 0;
    display: flex; flex-direction: column; gap: 10px;
    transition: all 0.2s;
    cursor: pointer;
    animation: fadeSlideUp 0.4s ease both;
  }

  .cert-card:hover {
    border-color: rgba(240,165,0,0.45);
    box-shadow: 0 8px 30px rgba(240,165,0,0.08);
    transform: translateY(-2px);
  }

  .cert-top {
    display: flex; align-items: center; gap: 8px;
  }

  .cert-icon {
    width: 36px; height: 36px; border-radius: var(--r-sm);
    background: var(--gold-dim); border: 1px solid rgba(240,165,0,0.3);
    display: flex; align-items: center; justify-content: center; font-size: 18px;
  }

  .cert-name {
    font-size: 12px; font-weight: 700; color: var(--gold); line-height: 1.3;
  }

  .cert-id {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px; color: var(--text-3);
  }

  .cert-date {
    font-size: 10px; color: var(--text-2);
    font-family: 'JetBrains Mono', monospace;
    display: flex; align-items: center; gap: 4px;
  }

  .cert-btn {
    padding: 6px 12px;
    background: var(--gold-dim);
    border: 1px solid rgba(240,165,0,0.3);
    border-radius: 6px;
    color: var(--gold);
    font-family: 'Exo 2', sans-serif;
    font-size: 10px; font-weight: 700;
    cursor: pointer; transition: all 0.2s;
    text-align: center; text-transform: uppercase; letter-spacing: 0.5px;
    width: 100%;
  }

  .cert-btn:hover {
    background: var(--gold); color: #000;
    box-shadow: 0 0 16px rgba(240,165,0,0.3);
  }

  /* ── LESSON VIEWER MODAL ── */
  .modal-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.85);
    backdrop-filter: blur(8px);
    z-index: 500;
    display: flex; align-items: flex-start;
    padding: 0;
    opacity: 0; pointer-events: none;
    transition: opacity 0.3s;
  }

  .modal-overlay.open { opacity: 1; pointer-events: all; }

  .lesson-modal {
    width: 100%; max-width: 100%; height: 100vh;
    display: flex; flex-direction: column;
    background: var(--bg);
    transform: translateY(20px);
    transition: transform 0.3s;
  }

  .modal-overlay.open .lesson-modal { transform: translateY(0); }

  .lesson-topbar {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 20px;
    background: var(--bg-nav);
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }

  .lesson-topbar-title {
    font-family: 'Orbitron', monospace;
    font-size: 12px; font-weight: 700; color: var(--text);
    flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  .lesson-prog-mini {
    display: flex; align-items: center; gap: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; color: var(--text-2);
  }

  .mini-bar {
    width: 100px; height: 4px;
    background: rgba(255,255,255,0.06); border-radius: 2px; overflow: hidden;
  }

  .mini-fill {
    height: 100%; border-radius: 2px;
    background: linear-gradient(90deg, var(--cyan), var(--green));
  }

  .btn-close-lesson {
    padding: 6px 14px; background: rgba(255,61,87,0.15);
    border: 1px solid rgba(255,61,87,0.3); color: var(--red);
    border-radius: 6px; font-family: 'Exo 2', sans-serif;
    font-size: 11px; font-weight: 700; cursor: pointer;
    transition: all 0.2s; text-transform: uppercase;
  }

  .btn-close-lesson:hover { background: var(--red); color: #fff; }

  .lesson-layout {
    display: flex; flex: 1; overflow: hidden;
  }

  /* lesson sidebar */
  .lesson-sidebar {
    width: 280px; flex-shrink: 0;
    background: var(--bg-nav);
    border-right: 1px solid var(--border);
    overflow-y: auto;
    padding: 16px 0;
  }

  .ls-header {
    padding: 0 16px 12px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 8px;
  }

  .ls-course-title {
    font-size: 12px; font-weight: 700; color: var(--gold);
    line-height: 1.4; margin-bottom: 4px;
  }

  .ls-stats {
    display: flex; gap: 10px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; color: var(--text-3);
  }

  .module-group { margin-bottom: 4px; }

  .module-title {
    padding: 6px 16px;
    font-size: 9px; font-weight: 700; letter-spacing: 1.5px;
    color: var(--text-3); text-transform: uppercase;
    font-family: 'JetBrains Mono', monospace;
  }

  .lesson-item {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 16px;
    cursor: pointer; transition: all 0.15s;
    border-left: 2px solid transparent;
  }

  .lesson-item:hover { background: var(--cyan-dim); border-left-color: rgba(0,212,255,0.3); }
  .lesson-item.active { background: var(--cyan-dim); border-left-color: var(--cyan); }
  .lesson-item.done { opacity: 0.6; }

  .li-status {
    width: 18px; height: 18px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 9px; flex-shrink: 0;
    border: 1px solid;
  }

  .li-status.done { background: var(--green-dim); border-color: var(--green); color: var(--green); }
  .li-status.active { background: var(--cyan-dim); border-color: var(--cyan); color: var(--cyan); }
  .li-status.locked { background: rgba(255,255,255,0.03); border-color: var(--text-3); color: var(--text-3); }

  .li-name { font-size: 11px; color: var(--text-2); line-height: 1.3; flex: 1; }
  .lesson-item.active .li-name { color: var(--text); font-weight: 600; }

  .li-dur { font-size: 9px; color: var(--text-3); font-family: 'JetBrains Mono', monospace; white-space: nowrap; }

  /* lesson content area */
  .lesson-content-area {
    flex: 1; overflow-y: auto; padding: 32px;
    display: flex; flex-direction: column;
  }

  .lc-header { margin-bottom: 24px; }

  .lc-breadcrumb {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; color: var(--text-3); letter-spacing: 1px;
    text-transform: uppercase; margin-bottom: 8px;
    display: flex; align-items: center; gap: 6px;
  }

  .lc-title {
    font-family: 'Orbitron', monospace;
    font-size: 20px; font-weight: 700; color: var(--text);
    margin-bottom: 8px; line-height: 1.3;
  }

  .lc-meta {
    display: flex; align-items: center; gap: 14px;
    font-size: 11px; color: var(--text-2);
    font-family: 'JetBrains Mono', monospace;
  }

