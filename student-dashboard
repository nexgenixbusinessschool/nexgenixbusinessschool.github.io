  const area = document.getElementById('lessonContentArea');
  let flatLessons = [];
  course.modules_list.forEach(mod => {
    mod.lessons.forEach(l => flatLessons.push({ ...l, modTitle: mod.title }));
  });
  const lesson = flatLessons[lessonIdx];
  if (!lesson) return;

  const total = flatLessons.length;
  const isLast = lessonIdx >= total - 1;
  const isFirst = lessonIdx === 0;

  area.innerHTML = `
    <div class="lc-header">
      <div class="lc-breadcrumb">
        <span>${course.id}</span> › <span>${lesson.modTitle}</span>
      </div>
      <div class="lc-title">${lesson.name}</div>
      <div class="lc-meta">
        <span>⏱ ${lesson.dur}</span>
        <span>📋 Lesson ${lessonIdx + 1} of ${total}</span>
        <span style="color:${lesson.done ? 'var(--green)' : 'var(--text-2)'};">${lesson.done ? '✅ Completed' : '🔄 In Progress'}</span>
      </div>
    </div>

    <div class="video-placeholder" onclick="alert('Video player would load here in production.')">
      <div class="play-btn">▶</div>
      <div class="video-label" style="position:relative;z-index:1;">Click to play lesson video</div>
      <div class="video-duration">${lesson.dur}</div>
    </div>

    <div class="key-points">
      <div class="kp-title">📌 Key Takeaways</div>
      <div class="kp-item">Core concepts covered in this lesson build on previous modules</div>
      <div class="kp-item">Practical exercises are included at the end of this session</div>
      <div class="kp-item">Review the supplementary reading materials for deeper understanding</div>
    </div>

    <div class="lesson-text">
      <h3>Overview</h3>
      <p>This lesson — <strong style="color:var(--text);">${lesson.name}</strong> — is part of <em>${lesson.modTitle}</em> within the <strong style="color:var(--gold);">${course.title}</strong> course. Here you'll develop a thorough, practical understanding of the subject matter through video instruction, guided exercises, and applied examples.</p>
      <p>Work through the material at your own pace. Once you've watched the video and reviewed the key takeaways above, mark the lesson complete to unlock the next one and track your progress.</p>
      <h3>Learning Objectives</h3>
      <p>By the end of this lesson, you'll be able to apply the core principles directly to real-world scenarios, connect this topic to the broader course framework, and prepare effectively for any assessments that follow.</p>
    </div>

    <div class="lesson-nav">
      <button class="btn-prev" onclick="navigateLesson(-1)" ${isFirst ? 'disabled style="opacity:0.3;cursor:not-allowed;"' : ''}>← Previous</button>
      ${!lesson.done
        ? `<button class="btn-complete" onclick="markComplete(${lessonIdx})">✓ Mark Complete</button>`
        : `<span style="font-size:11px;color:var(--green);font-family:'JetBrains Mono',monospace;">✅ Lesson Completed</span>`
      }
      <button class="btn-next" onclick="navigateLesson(1)" ${isLast ? 'disabled style="opacity:0.3;cursor:not-allowed;"' : ''}>Next Lesson →</button>
    </div>
  `;
}

function navigateLesson(dir) {
  let flatLessons = [];
  activeCourse.modules_list.forEach(mod => {
    mod.lessons.forEach(l => flatLessons.push(l));
  });
  const next = activeLessonIdx + dir;
  if (next >= 0 && next < flatLessons.length) {
    activeLessonIdx = next;
    renderLessonSidebar(activeCourse, activeLessonIdx);
    renderLessonContent(activeCourse, activeLessonIdx);
    document.getElementById('lessonContentArea').scrollTop = 0;
  }
}

function markComplete(idx) {
  let flatLessons = [];
  activeCourse.modules_list.forEach(mod => {
    mod.lessons.forEach(l => flatLessons.push(l));
  });
  if (flatLessons[idx]) {
    flatLessons[idx].done = true;
    flatLessons[idx].active = false;
    // update progress
    const doneCount = flatLessons.filter(l => l.done).length;
    activeCourse.progress = Math.round((doneCount / flatLessons.length) * 100);
    document.getElementById('modal-prog-label').textContent = activeCourse.progress + '%';
    document.getElementById('modal-mini-fill').style.width = activeCourse.progress + '%';
    renderLessonSidebar(activeCourse, idx);
    renderLessonContent(activeCourse, idx);
    renderEnrolled();
  }
}

function closeLesson() {
  document.getElementById('lessonModal').classList.remove('open');
  renderEnrolled();
}

function filterEnrolled(filter) {
  renderEnrolled(filter);
}

function showView(v) {
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  event.target.classList.add('active');
}

// init
renderEnrolled();
renderCompleted();
</script>
</body>
</html>
