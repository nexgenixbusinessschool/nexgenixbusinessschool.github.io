<style>
:root {
  --bg: #0b0f14;
  --surface: #111720;
  --surface2: #16202e;
  --border: #1e2d40;
  --accent: #a78bfa;
  --accent2: #f59e0b;
  --accent3: #10b981;
  --danger: #ef4444;
  --text: #e2eaf4;
  --muted: #5a7a99;
  --card: #0f1923;
  --pass: #10b981;
  --fail: #ef4444;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'Lora',serif;line-height:1.75;overflow-x:hidden}

/* ── HUD ── */
#hud{position:fixed;top:0;left:0;right:0;z-index:1000;background:rgba(11,15,20,0.93);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);}
.hud-inner{display:flex;align-items:center;gap:1rem;padding:0.6rem 1.5rem;max-width:1100px;margin:0 auto;}
.hud-logo{font-family:'Syne',sans-serif;font-weight:800;font-size:0.85rem;color:var(--accent);letter-spacing:0.05em;white-space:nowrap;}
.hud-lesson{font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:var(--muted);letter-spacing:0.1em;white-space:nowrap;}
.hud-progress-wrap{flex:1;display:flex;flex-direction:column;gap:0.25rem;}
.hud-progress-labels{display:flex;justify-content:space-between;font-family:'JetBrains Mono',monospace;font-size:0.6rem;color:var(--muted);}
.hud-bar{height:4px;background:var(--border);border-radius:2px;overflow:hidden;}
.hud-bar-fill{height:100%;width:0%;background:linear-gradient(90deg,var(--accent),var(--accent2));border-radius:2px;transition:width 0.3s ease;}
.hud-score{font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:var(--accent2);white-space:nowrap;text-align:right;min-width:80px;}
.hud-checkpoints{display:flex;gap:0.4rem;align-items:center;}
.checkpoint{width:8px;height:8px;border-radius:50%;background:var(--border);border:1px solid var(--muted);transition:all 0.3s;}
.checkpoint.done{background:var(--accent3);border-color:var(--accent3);box-shadow:0 0 6px var(--accent3);}
.checkpoint.quiz{background:var(--border);border-color:var(--accent2);}
.checkpoint.quiz.done{background:var(--accent2);border-color:var(--accent2);box-shadow:0 0 6px var(--accent2);}

/* ── HERO ── */
.hero{padding:7rem 2rem 4rem;max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr auto;gap:2rem;align-items:end;}
.hero-eyebrow{font-family:'JetBrains Mono',monospace;font-size:0.65rem;letter-spacing:0.25em;color:var(--accent);margin-bottom:1rem;display:flex;align-items:center;gap:0.75rem;}
.hero-eyebrow::before{content:'';width:2rem;height:1px;background:var(--accent);}
.hero h1{font-family:'Syne',sans-serif;font-weight:800;font-size:clamp(2.4rem,5vw,4rem);line-height:1.05;color:#fff;letter-spacing:-0.03em;}
.hero h1 span{color:var(--accent);}
.hero-sub{margin-top:1rem;font-size:1.05rem;color:var(--muted);font-style:italic;max-width:600px;}
.hero-meta{text-align:right;}
.meta-badge{font-family:'JetBrains Mono',monospace;font-size:0.65rem;letter-spacing:0.1em;color:var(--muted);display:block;line-height:2;}
.meta-badge b{color:var(--accent2);}

/* ── LAYOUT ── */
.course-wrap{max-width:820px;margin:0 auto;padding:0 2rem 8rem;}

/* ── HEADINGS ── */
.sec-label{font-family:'JetBrains Mono',monospace;font-size:0.6rem;letter-spacing:0.2em;color:var(--accent);margin-bottom:0.5rem;display:flex;align-items:center;gap:0.75rem;}
.sec-label::before{content:'';width:1rem;height:1px;background:var(--accent);}
.content-section{margin-bottom:4rem;padding-top:1rem;}
h2{font-family:'Syne',sans-serif;font-weight:700;font-size:clamp(1.4rem,3vw,2rem);color:#fff;margin-bottom:1.25rem;padding-bottom:0.75rem;border-bottom:1px solid var(--border);position:relative;}
h2::after{content:'';position:absolute;bottom:-1px;left:0;width:3rem;height:1px;background:var(--accent);}
h3{font-family:'Syne',sans-serif;font-size:1.05rem;font-weight:600;color:var(--accent2);margin:1.75rem 0 0.6rem;}
p{font-size:0.97rem;color:#b8cfe0;margin-bottom:1rem;}
strong{color:var(--text);}

/* ── CALLOUT ── */
.callout{border-left:3px solid var(--accent2);background:rgba(245,158,11,0.06);padding:1rem 1.25rem;margin:1.5rem 0;font-style:italic;font-size:0.9rem;color:#c0a060;}

/* ── COLOR SWATCH CARDS ── */
.color-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem;margin:1.25rem 0;}
.color-card{background:var(--card);border:1px solid var(--border);overflow:hidden;transition:transform 0.2s,border-color 0.2s;}
.color-card:hover{transform:translateY(-2px);border-color:var(--accent);}
.color-swatch{height:56px;width:100%;}
.color-body{padding:0.9rem 1rem;}
.color-name{font-family:'Syne',sans-serif;font-weight:700;font-size:0.9rem;color:#fff;margin-bottom:0.3rem;}
.color-desc{font-size:0.8rem;color:var(--muted);line-height:1.5;}

/* ── INDUSTRY BLOCKS ── */
.industry-block{background:var(--surface);border:1px solid var(--border);border-left:3px solid var(--accent);padding:1.5rem 1.75rem;margin-bottom:2rem;}
.industry-block h3{margin-top:0;color:var(--accent);}

/* ── PALETTE SECTION TITLE ── */
.palette-title{font-family:'Syne',sans-serif;font-weight:700;font-size:1rem;color:#fff;margin:1.25rem 0 0.75rem;display:flex;align-items:center;gap:0.5rem;}
.palette-title::before{content:'';width:3px;height:1rem;background:var(--accent);display:inline-block;}

/* ── QUIZ BLOCK ── */
.quiz-block{background:var(--surface);border:1px solid var(--border);border-top:3px solid var(--accent2);padding:2rem;margin:3.5rem 0;position:relative;overflow:hidden;}
.quiz-block::before{content:'';position:absolute;top:0;right:0;width:120px;height:120px;background:radial-gradient(circle,rgba(245,158,11,0.06) 0%,transparent 70%);pointer-events:none;}
.quiz-header{display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem;}
.quiz-icon{width:2.5rem;height:2.5rem;background:rgba(245,158,11,0.12);border:1px solid rgba(245,158,11,0.3);display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0;}
.quiz-title{font-family:'Syne',sans-serif;font-weight:700;font-size:1.15rem;color:#fff;}
.quiz-subtitle{font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:var(--accent2);letter-spacing:0.1em;margin-top:0.2rem;}
.question{margin-bottom:1.75rem;}
.q-text{font-family:'Syne',sans-serif;font-size:0.95rem;font-weight:600;color:#fff;margin-bottom:0.85rem;display:flex;gap:0.75rem;}
.q-num{font-family:'JetBrains Mono',monospace;font-size:0.7rem;background:var(--accent2);color:var(--bg);min-width:1.5rem;height:1.5rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:0.1rem;font-weight:500;}
.options{display:flex;flex-direction:column;gap:0.5rem;padding-left:0.25rem;}
.option-label{display:flex;align-items:center;gap:0.75rem;padding:0.65rem 1rem;background:var(--card);border:1px solid var(--border);cursor:pointer;transition:all 0.15s;font-size:0.9rem;color:#b8cfe0;}
.option-label:hover{border-color:var(--accent2);color:#fff;}
.option-label input{display:none;}
.option-label.selected{background:rgba(245,158,11,0.08);border-color:var(--accent2);color:#fff;}
.option-label.correct{background:rgba(16,185,129,0.12);border-color:var(--accent3);color:var(--accent3);}
.option-label.wrong{background:rgba(239,68,68,0.1);border-color:var(--danger);color:var(--danger);}
.option-label.reveal-correct{background:rgba(16,185,129,0.08);border-color:var(--accent3);color:var(--accent3);}
.opt-letter{font-family:'JetBrains Mono',monospace;font-size:0.65rem;background:var(--surface2);color:var(--muted);min-width:1.4rem;height:1.4rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all 0.15s;}
.option-label.selected .opt-letter{background:var(--accent2);color:var(--bg);}
.option-label.correct .opt-letter{background:var(--accent3);color:var(--bg);}
.option-label.wrong .opt-letter{background:var(--danger);color:#fff;}
.quiz-footer{display:flex;align-items:center;gap:1rem;margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid var(--border);}
.btn-submit{font-family:'Syne',sans-serif;font-weight:700;font-size:0.85rem;letter-spacing:0.05em;background:var(--accent2);color:var(--bg);border:none;padding:0.7rem 2rem;cursor:pointer;transition:all 0.2s;}
.btn-submit:hover{background:#fbbf24;transform:translateY(-1px);}
.btn-submit:disabled{background:var(--border);color:var(--muted);cursor:not-allowed;transform:none;}
.quiz-result{display:none;font-family:'JetBrains Mono',monospace;font-size:0.75rem;padding:0.75rem 1rem;flex:1;}
.quiz-result.pass{background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:var(--accent3);}
.quiz-result.fail{background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.25);color:var(--danger);}

/* ── FINAL EXAM ── */
.exam-block{background:var(--surface);border:2px solid var(--accent);padding:2.5rem;margin:4rem 0;position:relative;}
.exam-block::after{content:'FINAL EXAM';position:absolute;top:-0.7rem;left:1.5rem;font-family:'JetBrains Mono',monospace;font-size:0.65rem;letter-spacing:0.2em;background:var(--accent);color:var(--bg);padding:0.2rem 0.75rem;font-weight:500;}

/* ── SCORE SUMMARY ── */
#score-summary{display:none;background:var(--surface);border:1px solid var(--border);padding:2rem;margin:3rem 0;text-align:center;}
.score-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin:1.5rem 0;}
.score-item{background:var(--card);border:1px solid var(--border);padding:1rem;}
.score-item-label{font-family:'JetBrains Mono',monospace;font-size:0.6rem;color:var(--muted);letter-spacing:0.1em;margin-bottom:0.4rem;}
.score-item-val{font-family:'Syne',sans-serif;font-weight:800;font-size:1.8rem;}
.score-item-val.good{color:var(--accent3);}
.score-item-val.ok{color:var(--accent2);}
.score-item-val.bad{color:var(--danger);}

/* ── CERTIFICATE ── */
#cert-section{display:none;margin:4rem 0;animation:fadeUp 0.8s both;}
@keyframes fadeUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
.cert-unlock{text-align:center;margin-bottom:2rem;font-family:'JetBrains Mono',monospace;font-size:0.75rem;color:var(--accent3);letter-spacing:0.15em;}
.cert-unlock::before{content:'✓ '}
#certificate{background:#fff;color:#111;padding:3.5rem;border:8px solid #7c3aed;box-shadow:0 0 0 2px #7c3aed,0 0 0 4px #fff,0 0 0 6px #7c3aed;max-width:700px;margin:0 auto;position:relative;font-family:'Lora',serif;text-align:center;}
.cert-corner{position:absolute;width:50px;height:50px;border:2px solid #7c3aed;}
.cert-corner.tl{top:12px;left:12px;border-right:none;border-bottom:none;}
.cert-corner.tr{top:12px;right:12px;border-left:none;border-bottom:none;}
.cert-corner.bl{bottom:12px;left:12px;border-right:none;border-top:none;}
.cert-corner.br{bottom:12px;right:12px;border-left:none;border-top:none;}
.cert-school{font-family:'Syne',sans-serif;font-weight:800;font-size:0.8rem;letter-spacing:0.25em;color:#888;margin-bottom:0.5rem;text-transform:uppercase;}
.cert-title{font-family:'Syne',sans-serif;font-weight:800;font-size:1.8rem;color:#7c3aed;letter-spacing:0.1em;margin-bottom:0.25rem;text-transform:uppercase;}
.cert-subtitle{font-size:0.85rem;color:#888;margin-bottom:1.5rem;letter-spacing:0.05em;}
.cert-presents{font-size:0.9rem;color:#888;margin-bottom:0.5rem;}
.cert-name{font-family:'Syne',sans-serif;font-weight:800;font-size:2.2rem;color:#1a2535;margin:0.25rem 0 1.25rem;letter-spacing:-0.02em;border-bottom:2px solid #7c3aed;display:inline-block;padding-bottom:0.25rem;}
.cert-body{font-size:0.9rem;color:#444;margin-bottom:1.5rem;line-height:1.6;}
.cert-course{font-family:'Syne',sans-serif;font-weight:700;font-size:1.1rem;color:#1a2535;margin-bottom:0.5rem;}
.cert-grade{display:inline-block;font-family:'JetBrains Mono',monospace;font-size:0.8rem;background:#1a2535;color:#a78bfa;padding:0.3rem 1rem;margin-bottom:1.75rem;letter-spacing:0.1em;}
.cert-sigs{display:flex;justify-content:space-around;margin-top:1.5rem;padding-top:1rem;border-top:1px solid #ddd;}
.cert-sig{text-align:center;}
.cert-sig-line{width:120px;height:1px;background:#aaa;margin:0 auto 0.4rem;}
.cert-sig-name{font-size:0.75rem;color:#555;letter-spacing:0.05em;}
.cert-sig-role{font-size:0.65rem;color:#aaa;letter-spacing:0.05em;}
.cert-seal{position:absolute;bottom:1.5rem;right:2rem;width:70px;height:70px;border-radius:50%;border:3px solid #7c3aed;display:flex;align-items:center;justify-content:center;font-size:0.5rem;font-family:'Syne',sans-serif;font-weight:700;color:#7c3aed;letter-spacing:0.1em;text-align:center;line-height:1.3;text-transform:uppercase;}
.cert-form{max-width:700px;margin:0 auto 2rem;display:flex;gap:1rem;}
.cert-form input{flex:1;background:var(--card);border:1px solid var(--border);color:#fff;padding:0.75rem 1rem;font-family:'Lora',serif;font-size:0.95rem;outline:none;}
.cert-form input:focus{border-color:var(--accent);}
.cert-form input::placeholder{color:var(--muted);}
.btn-cert{font-family:'Syne',sans-serif;font-weight:700;font-size:0.85rem;background:var(--accent3);color:var(--bg);border:none;padding:0.75rem 1.5rem;cursor:pointer;transition:background 0.2s;white-space:nowrap;}
.btn-cert:hover{background:#34d399;}
.btn-print{display:block;margin:1.5rem auto 0;font-family:'Syne',sans-serif;font-weight:700;font-size:0.85rem;background:transparent;color:var(--accent2);border:1px solid var(--accent2);padding:0.65rem 2rem;cursor:pointer;transition:all 0.2s;}
.btn-print:hover{background:var(--accent2);color:var(--bg);}

/* ── DIVIDER ── */
.divider{display:flex;align-items:center;gap:1rem;margin:3rem 0;}
.divider::before,.divider::after{content:'';flex:1;height:1px;background:var(--border);}
.divider span{font-family:'JetBrains Mono',monospace;font-size:0.6rem;letter-spacing:0.2em;color:var(--muted);white-space:nowrap;}

/* ── LESSON NAV ── */
.lesson-nav{display:flex;gap:1rem;margin-bottom:3rem;}
.lesson-nav a{font-family:'JetBrains Mono',monospace;font-size:0.7rem;letter-spacing:0.1em;color:var(--muted);text-decoration:none;border:1px solid var(--border);padding:0.5rem 1rem;transition:all 0.2s;}
.lesson-nav a:hover{border-color:var(--accent);color:var(--accent);}
.lesson-nav a.active{border-color:var(--accent);color:var(--accent);background:rgba(167,139,250,0.08);}

/* SCROLLBAR */
::-webkit-scrollbar{width:6px;}
::-webkit-scrollbar-track{background:var(--bg);}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px;}

/* PRINT */
@media print{body>*:not(#cert-section){display:none!important;}#cert-section{display:block!important;}#hud,.cert-form,.btn-print{display:none!important;}#certificate{box-shadow:none!important;}}

@media(max-width:600px){
  .hero{grid-template-columns:1fr;}.hero-meta{display:none;}
  .score-grid{grid-template-columns:1fr;}.cert-form{flex-direction:column;}
  #certificate{padding:2rem 1.25rem;}.color-grid{grid-template-columns:1fr 1fr;}
}
</style>
