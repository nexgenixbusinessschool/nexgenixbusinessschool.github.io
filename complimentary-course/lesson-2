        <label class="option-label"><input type="radio" name="q2_8" value="B"><span class="opt-letter">B</span>Art and science (creativity and strategy)</label>
        <label class="option-label"><input type="radio" name="q2_8" value="C"><span class="opt-letter">C</span>Photography and writing</label>
        <label class="option-label"><input type="radio" name="q2_8" value="D"><span class="opt-letter">D</span>Sales and distribution</label>
      </div>
    </div>

    <div class="question">
      <div class="q-text"><span class="q-num">9</span>Which color in the cosmetics category conveys purity, cleanliness, and freshness — reassuring consumers about quality and safety?</div>
      <div class="options">
        <label class="option-label"><input type="radio" name="q2_9" value="A"><span class="opt-letter">A</span>Black</label>
        <label class="option-label"><input type="radio" name="q2_9" value="B"><span class="opt-letter">B</span>Gold</label>
        <label class="option-label"><input type="radio" name="q2_9" value="C"><span class="opt-letter">C</span>White</label>
        <label class="option-label"><input type="radio" name="q2_9" value="D"><span class="opt-letter">D</span>Pink</label>
      </div>
    </div>

    <div class="question">
      <div class="q-text"><span class="q-num">10</span>According to the lesson, what is the correct order when building a brand's visual identity?</div>
      <div class="options">
        <label class="option-label"><input type="radio" name="q2_10" value="A"><span class="opt-letter">A</span>Choose the color palette first, then design the logo, then name the brand</label>
        <label class="option-label"><input type="radio" name="q2_10" value="B"><span class="opt-letter">B</span>Design the logo first, then establish the brand name</label>
        <label class="option-label"><input type="radio" name="q2_10" value="C"><span class="opt-letter">C</span>Establish the brand name first, then use it to guide the color palette and visual identity</label>
        <label class="option-label"><input type="radio" name="q2_10" value="D"><span class="opt-letter">D</span>The order does not matter as long as all elements are completed</label>
      </div>
    </div>

    <div class="quiz-footer">
      <button class="btn-submit" id="submit-q2" onclick="submitQuiz(2)">Submit Final Exam</button>
      <div class="quiz-result" id="result-q2"></div>
    </div>
  </div>

  <!-- ── SCORE SUMMARY ── -->
  <div id="score-summary">
    <div class="sec-label" style="justify-content:center;margin-bottom:0.75rem;">Assessment Complete</div>
    <h2 style="text-align:center;border:none;">Your Results</h2>
    <div class="score-grid">
      <div class="score-item"><div class="score-item-label">QUIZ 1 SCORE</div><div class="score-item-val" id="sum-q1">—</div></div>
      <div class="score-item"><div class="score-item-label">FINAL EXAM SCORE</div><div class="score-item-val" id="sum-q2">—</div></div>
      <div class="score-item"><div class="score-item-label">OVERALL GRADE</div><div class="score-item-val" id="sum-overall">—</div></div>
    </div>
    <p id="sum-verdict" style="font-family:'JetBrains Mono',monospace;font-size:0.8rem;color:var(--muted);"></p>
  </div>

  <!-- ── CERTIFICATE ── -->
  <div id="cert-section">
    <div class="cert-unlock">Certificate Unlocked — Enter your name to generate</div>
    <div class="cert-form">
      <input type="text" id="student-name" placeholder="Enter your full name…" maxlength="60">
      <button class="btn-cert" onclick="generateCert()">Generate Certificate</button>
    </div>
    <div id="certificate">
      <div class="cert-corner tl"></div><div class="cert-corner tr"></div>
      <div class="cert-corner bl"></div><div class="cert-corner br"></div>
      <div class="cert-school">Nex Genix Business School</div>
      <div class="cert-title">Certificate</div>
      <div class="cert-subtitle">of Completion</div>
      <div class="cert-presents">This certifies that</div>
      <div class="cert-name" id="cert-name-display">—</div>
      <div class="cert-body">
        has successfully completed all assessments for<br>
        <strong>Module 2: Business Course — Logo Design</strong><br>
        demonstrating a solid understanding of brand identity,<br>
        logo design principles, and color psychology.
      </div>
      <div class="cert-course">Business Course: Logo Design</div>
      <div class="cert-grade" id="cert-grade-display">GRADE: —</div>
      <div class="cert-sigs">
        <div class="cert-sig"><div class="cert-sig-line"></div><div class="cert-sig-name">Nex Genix</div><div class="cert-sig-role">Course Director</div></div>
        <div class="cert-sig"><div class="cert-sig-line"></div><div class="cert-sig-name" id="cert-date-display">—</div><div class="cert-sig-role">Date of Completion</div></div>
      </div>
      <div class="cert-seal">NEX<br>GENIX<br>★</div>
    </div>
    <button class="btn-print" onclick="window.print()">⎙ Save / Print Certificate</button>
  </div>

</div><!-- /course-wrap -->

<script>
// ── ANSWER KEY ──
const ANSWERS = {
  quiz1: { q1_1:'B', q1_2:'C', q1_3:'B', q1_4:'C', q1_5:'B' },
  quiz2: { q2_1:'C', q2_2:'B', q2_3:'C', q2_4:'B', q2_5:'C',
           q2_6:'C', q2_7:'B', q2_8:'B', q2_9:'C', q2_10:'C' }
};
let scores = { q1: null, q2: null };

// Option highlight
document.querySelectorAll('.option-label').forEach(label => {
  label.addEventListener('click', function() {
    const name = this.querySelector('input').name;
    document.querySelectorAll(`input[name="${name}"]`).forEach(inp => {
      inp.closest('.option-label').classList.remove('selected');
    });
    this.classList.add('selected');
  });
});

function submitQuiz(qNum) {
  const isQ1 = qNum === 1;
  const key = isQ1 ? 'quiz1' : 'quiz2';
  const prefix = isQ1 ? 'q1_' : 'q2_';
  const total = isQ1 ? 5 : 10;
  const passingPct = isQ1 ? 60 : 70;
  const answers = ANSWERS[key];
  let correct = 0;

  const block = document.getElementById(isQ1 ? 'quiz1' : 'quiz2');
  block.querySelectorAll('.option-label').forEach(l => { l.style.cursor='default'; l.style.pointerEvents='none'; });

  for (let i = 1; i <= total; i++) {
    const qKey = prefix + i;
    const correctAns = answers[qKey];
    const selected = document.querySelector(`input[name="${qKey}"]:checked`);
    document.querySelectorAll(`input[name="${qKey}"]`).forEach(inp => {
      if (inp.value === correctAns) inp.closest('.option-label').classList.add('reveal-correct');
    });
    if (selected) {
      const lbl = selected.closest('.option-label');
      if (selected.value === correctAns) { lbl.classList.remove('selected','reveal-correct'); lbl.classList.add('correct'); correct++; }
      else { lbl.classList.remove('selected'); lbl.classList.add('wrong'); }
    }
  }

  const pct = Math.round((correct / total) * 100);
  const passed = pct >= passingPct;
  scores[`q${qNum}`] = pct;

  const resultEl = document.getElementById(`result-q${qNum}`);
  resultEl.style.display = 'block';
  resultEl.className = 'quiz-result ' + (passed ? 'pass' : 'fail');
  resultEl.innerHTML = passed
    ? `✓ PASSED &nbsp;|&nbsp; ${correct}/${total} correct &nbsp;(${pct}%) &nbsp;— Well done!`
    : `✗ FAILED &nbsp;|&nbsp; ${correct}/${total} correct &nbsp;(${pct}%) &nbsp;— Review and try again.`;
  document.getElementById(`submit-q${qNum}`).disabled = true;

  if (passed) document.getElementById(isQ1 ? 'cp2' : 'cp5').classList.add('done');
  updateHudScore();
  if (scores.q1 !== null && scores.q2 !== null) showSummary();
}

function updateHudScore() {
  const parts = [];
  if (scores.q1 !== null) parts.push(`Q1:${scores.q1}%`);
  if (scores.q2 !== null) parts.push(`Exam:${scores.q2}%`);
  document.getElementById('hud-score').textContent = parts.length ? parts.join('  ') : 'Score: —';
}

function showSummary() {
  const s = document.getElementById('score-summary');
  s.style.display = 'block';
  s.scrollIntoView({ behavior:'smooth', block:'start' });
  const q1 = scores.q1, q2 = scores.q2;
  const overall = Math.round((q1 + q2 * 2) / 3);
  const el1 = document.getElementById('sum-q1');
  const el2 = document.getElementById('sum-q2');
  const elO = document.getElementById('sum-overall');
  el1.textContent = q1 + '%'; el1.className = 'score-item-val ' + colorClass(q1, 60);
  el2.textContent = q2 + '%'; el2.className = 'score-item-val ' + colorClass(q2, 70);
  elO.textContent = overall + '%'; elO.className = 'score-item-val ' + colorClass(overall, 65);
  const examPassed = q2 >= 70;
  document.getElementById('sum-verdict').textContent = examPassed
    ? '🎓 Final Exam passed! You have unlocked your certificate below.'
    : '📖 Final Exam not yet passed (need 70%). Review the lesson and resubmit.';
  if (examPassed) setTimeout(() => { const cs = document.getElementById('cert-section'); cs.style.display='block'; cs.scrollIntoView({behavior:'smooth'}); }, 600);
}

function colorClass(pct, threshold) {
  if (pct >= threshold + 20) return 'good';
  if (pct >= threshold) return 'ok';
  return 'bad';
}

function generateCert() {
  const name = document.getElementById('student-name').value.trim();
  if (!name) { alert('Please enter your full name.'); return; }
  const q2 = scores.q2;
  const grade = q2 >= 90 ? 'A (Excellent)' : q2 >= 80 ? 'B (Very Good)' : q2 >= 70 ? 'C (Satisfactory)' : 'Below Passing';
  document.getElementById('cert-name-display').textContent = name;
  document.getElementById('cert-grade-display').textContent = `GRADE: ${grade} · ${q2}%`;
  const dateStr = new Date().toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' });
  document.getElementById('cert-date-display').textContent = dateStr;
}

// ── SCROLL PROGRESS ──
const checkpointMap = [
  { id:'sec-intro',     cp:'cp0' },
  { id:'sec-brandname', cp:'cp1' },
  { id:'quiz1',         cp:'cp2' },
  { id:'sec-colors',    cp:'cp3' },
  { id:'sec-industry',  cp:'cp4' },
  { id:'quiz2',         cp:'cp5' },
];

function onScroll() {
  const scrollTop = window.scrollY || document.documentElement.scrollTop;
  const docH = document.documentElement.scrollHeight - window.innerHeight;
  const pct = docH > 0 ? Math.min(100, Math.round((scrollTop / docH) * 100)) : 0;
  document.getElementById('scroll-bar').style.width = pct + '%';
  document.getElementById('pct-label').textContent = pct + '%';
  checkpointMap.forEach(({ id, cp }) => {
    const el = document.getElementById(id);
    if (!el) return;
    if (el.getBoundingClientRect().top < window.innerHeight * 0.85) {
      const cpEl = document.getElementById(cp);
      if (!cpEl.classList.contains('done') && !cpEl.classList.contains('quiz')) cpEl.classList.add('done');
    }
  });
}
window.addEventListener('scroll', onScroll, { passive:true });
onScroll();
</script>
</body>
</html>
